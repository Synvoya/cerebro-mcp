  "repository": {
    "type": "git",
    "url": "https://github.com/Synvoya/cerebro-mcp.git"
  },
  "homepage": "https://cerebro.synvoya.com",
  "bugs": {
    "url": "https://github.com/Synvoya/cerebro-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.8.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.17",
