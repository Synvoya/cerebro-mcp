{
  "name": "@synvoya/cerebro-mcp",
  "version": "2.1.0",
  "description": "Universal AI orchestrator — MCP for tools, A2A for agents. Chat thinks, agents specialize, CLI codes.",
  "type": "module",
  "bin": {
    "cerebro-mcp": "./build/index.js"
  },
  "files": [
    "build",
    "agents",
    "starter-kits"
  ],
  "scripts": {
